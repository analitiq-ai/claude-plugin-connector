{
  "$id": "https://schemas.analitiq.ai/connection/10.0.0.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Public JSON Schema contract for Analitiq connection documents \u2014 the authored shape used in source control, PR review, and author-time tooling. Server-managed fields (connection_id, version, org_id, connector_id, connector_version, auth_state, created_at, updated_at) are forbidden in the authored shape and assigned by the connection service on ingest. The persisted-record shape is internal and not published. Source of truth: analitiq.contracts.connection.ConnectionInput (Pydantic).",
  "properties": {
    "$schema": {
      "anyOf": [
        {
          "const": "https://schemas.analitiq.ai/connection/latest.json",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Connection schema URL (optional in API payloads, required for standalone files).",
      "title": "$Schema"
    },
    "connection_id": {
      "anyOf": [
        {
          "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Connection UUID (RFC-4122). Optional in authored definitions so external publishers can assign their own identifier; service-assigned on ingest when omitted.",
      "title": "Connection Id"
    },
    "connector_id": {
      "description": "Identifier of the connector this connection configures. Non-empty string; the registry assigns connector identifiers (UUID or slug \u2014 not constrained at the schema level).",
      "minLength": 1,
      "title": "Connector Id",
      "type": "string"
    },
    "description": {
      "anyOf": [
        {
          "maxLength": 2000,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "User-facing summary.",
      "title": "Description"
    },
    "discovered": {
      "additionalProperties": true,
      "description": "Durable provider-discovered non-secret values keyed by post-auth output key. Spec: \u00a7Post-Auth Outputs.",
      "propertyNames": {
        "not": {
          "pattern": "(?:^|_)(?:[Aa][Cc][Cc][Ee][Ss][Ss]|[Rr][Ee][Ff][Rr][Ee][Ss][Hh]|[Ii][Dd]|[Bb][Ee][Aa][Rr][Ee][Rr]|[Oo][Aa][Uu][Tt][Hh]|[Aa][Uu][Tt][Hh]|[Ss][Ee][Ss][Ss][Ii][Oo][Nn]|[Ss][Aa][Ss]|[Aa][Pp][Ii])_?[Tt][Oo][Kk][Ee][Nn]$|(?:^|_)(?:[Aa][Pp][Ii]|[Aa][Cc][Cc][Ee][Ss][Ss]|[Ss][Ee][Cc][Rr][Ee][Tt]|[Ss][Ii][Gg][Nn][Ii][Nn][Gg]|[Pp][Rr][Ii][Vv][Aa][Tt][Ee]|[Ee][Nn][Cc][Rr][Yy][Pp][Tt][Ii][Oo][Nn]|[Aa][Cc][Cc][Oo][Uu][Nn][Tt]|[Ss][Ee][Rr][Vv][Ii][Cc][Ee]_[Aa][Cc][Cc][Oo][Uu][Nn][Tt])_?[Kk][Ee][Yy]$|[Cc][Ee][Rr][Tt]_(?:[Pp][Ee][Mm]|[Kk][Ee][Yy])$|(?:^|_)[Aa][Ss][Ss][Ee][Rr][Tt][Ii][Oo][Nn]$|(?:^|_)[Ss][Ee][Cc][Rr][Ee][Tt](?:_|$)|(?:^|_)[Pp][Aa][Ss][Ss][Ww][Oo][Rr][Dd](?:_|$)|(?:^|_)(?:[Pp][Ww][Dd]|[Pp][Aa][Tt]|[Pp][Kk][Ee][Yy]|[Cc][Rr][Ee][Dd][Ss])(?:_|$)|(?:^|_)[Pp][Aa][Ss][Ss][Ww][Dd](?:_|$)|(?:^|_)[Cc][Ll][Ii][Ee][Nn][Tt]_[Ss][Ee][Cc][Rr][Ee][Tt](?:_|$)|(?:^|_)[Cc][Rr][Ee][Dd][Ee][Nn][Tt][Ii][Aa][Ll][Ss]?(?:_|$)|(?:^|_)[Cc][Oo][Nn][Nn][Ee][Cc][Tt][Ii][Oo][Nn]_[Ss][Tt][Rr][Ii][Nn][Gg](?:_|$)|^[Aa][Ss][Ss][Ee][Rr][Tt][Ii][Oo][Nn]$|^[Cc][Rr][Ee][Dd][Ee][Nn][Tt][Ii][Aa][Ll]$|^[Cc][Rr][Ee][Dd][Ee][Nn][Tt][Ii][Aa][Ll][Ss]$|^[Cc][Rr][Ee][Dd][Ss]$|^[Kk][Ee][Yy]$|^[Pp][Aa][Ss][Ss][Ww][Dd]$|^[Pp][Aa][Ss][Ss][Ww][Oo][Rr][Dd]$|^[Pp][Aa][Tt]$|^[Pp][Kk][Ee][Yy]$|^[Pp][Ww][Dd]$|^[Ss][Ee][Cc][Rr][Ee][Tt]$|^[Tt][Oo][Kk][Ee][Nn]$"
        }
      },
      "title": "Discovered",
      "type": "object"
    },
    "display_name": {
      "anyOf": [
        {
          "maxLength": 120,
          "minLength": 1,
          "pattern": "^\\S(?:[\\s\\S]*\\S)?$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "User-facing connection label (1-120 chars, no leading/trailing whitespace).",
      "title": "Display Name"
    },
    "parameters": {
      "additionalProperties": true,
      "description": "Non-secret submitted values keyed by connection-contract input key. Per-key value vocabularies (enums, formats, etc.) are authored on the owning connector's `connection_contract.inputs.<key>` and enforced server-side on save.",
      "propertyNames": {
        "not": {
          "pattern": "(?:^|_)(?:[Aa][Cc][Cc][Ee][Ss][Ss]|[Rr][Ee][Ff][Rr][Ee][Ss][Hh]|[Ii][Dd]|[Bb][Ee][Aa][Rr][Ee][Rr]|[Oo][Aa][Uu][Tt][Hh]|[Aa][Uu][Tt][Hh]|[Ss][Ee][Ss][Ss][Ii][Oo][Nn]|[Ss][Aa][Ss]|[Aa][Pp][Ii])_?[Tt][Oo][Kk][Ee][Nn]$|(?:^|_)(?:[Aa][Pp][Ii]|[Aa][Cc][Cc][Ee][Ss][Ss]|[Ss][Ee][Cc][Rr][Ee][Tt]|[Ss][Ii][Gg][Nn][Ii][Nn][Gg]|[Pp][Rr][Ii][Vv][Aa][Tt][Ee]|[Ee][Nn][Cc][Rr][Yy][Pp][Tt][Ii][Oo][Nn]|[Aa][Cc][Cc][Oo][Uu][Nn][Tt]|[Ss][Ee][Rr][Vv][Ii][Cc][Ee]_[Aa][Cc][Cc][Oo][Uu][Nn][Tt])_?[Kk][Ee][Yy]$|[Cc][Ee][Rr][Tt]_(?:[Pp][Ee][Mm]|[Kk][Ee][Yy])$|(?:^|_)[Aa][Ss][Ss][Ee][Rr][Tt][Ii][Oo][Nn]$|(?:^|_)[Ss][Ee][Cc][Rr][Ee][Tt](?:_|$)|(?:^|_)[Pp][Aa][Ss][Ss][Ww][Oo][Rr][Dd](?:_|$)|(?:^|_)(?:[Pp][Ww][Dd]|[Pp][Aa][Tt]|[Pp][Kk][Ee][Yy]|[Cc][Rr][Ee][Dd][Ss])(?:_|$)|(?:^|_)[Pp][Aa][Ss][Ss][Ww][Dd](?:_|$)|(?:^|_)[Cc][Ll][Ii][Ee][Nn][Tt]_[Ss][Ee][Cc][Rr][Ee][Tt](?:_|$)|(?:^|_)[Cc][Rr][Ee][Dd][Ee][Nn][Tt][Ii][Aa][Ll][Ss]?(?:_|$)|(?:^|_)[Cc][Oo][Nn][Nn][Ee][Cc][Tt][Ii][Oo][Nn]_[Ss][Tt][Rr][Ii][Nn][Gg](?:_|$)|^[Aa][Ss][Ss][Ee][Rr][Tt][Ii][Oo][Nn]$|^[Cc][Rr][Ee][Dd][Ee][Nn][Tt][Ii][Aa][Ll]$|^[Cc][Rr][Ee][Dd][Ee][Nn][Tt][Ii][Aa][Ll][Ss]$|^[Cc][Rr][Ee][Dd][Ss]$|^[Kk][Ee][Yy]$|^[Pp][Aa][Ss][Ss][Ww][Dd]$|^[Pp][Aa][Ss][Ss][Ww][Oo][Rr][Dd]$|^[Pp][Aa][Tt]$|^[Pp][Kk][Ee][Yy]$|^[Pp][Ww][Dd]$|^[Ss][Ee][Cc][Rr][Ee][Tt]$|^[Tt][Oo][Kk][Ee][Nn]$"
        }
      },
      "title": "Parameters",
      "type": "object"
    },
    "secret_refs": {
      "additionalProperties": {
        "pattern": "^(?:env:[A-Za-z_][A-Za-z0-9_]*|file:[A-Za-z0-9_.][A-Za-z0-9_./\\-]*|s3://[A-Za-z0-9._\\-]+/[A-Za-z0-9_./\\-]+|arn:aws:secretsmanager:[A-Za-z0-9\\-]+:\\d+:secret:[A-Za-z0-9/_\\-+=.@]+|arn:aws:ssm:[A-Za-z0-9\\-]+:\\d+:parameter/[A-Za-z0-9_./\\-]+|ssm:/[A-Za-z0-9_./\\-]+|sidecar:.+)$",
        "type": "string"
      },
      "description": "Opaque secret-store references keyed by connection-contract input or post-auth output key. Every value carries an explicit cloud-free scheme: `env:<VAR>`, `file:<./path>`, `s3://<bucket>/<key>`, `arn:aws:secretsmanager:<region>:<acct>:secret:<id>`, `arn:aws:ssm:<region>:<acct>:parameter/<id>`, `ssm:/<path>`, or `sidecar:<name>` (entry `<name>` in the connection's local credentials secrets file). Spec: \u00a7Secret Storage Materialization.",
      "title": "Secret Refs",
      "type": "object"
    },
    "selections": {
      "additionalProperties": true,
      "description": "Durable user-selected post-auth values keyed by post-auth output key. Spec: \u00a7Post-Auth Outputs.",
      "propertyNames": {
        "not": {
          "pattern": "(?:^|_)(?:[Aa][Cc][Cc][Ee][Ss][Ss]|[Rr][Ee][Ff][Rr][Ee][Ss][Hh]|[Ii][Dd]|[Bb][Ee][Aa][Rr][Ee][Rr]|[Oo][Aa][Uu][Tt][Hh]|[Aa][Uu][Tt][Hh]|[Ss][Ee][Ss][Ss][Ii][Oo][Nn]|[Ss][Aa][Ss]|[Aa][Pp][Ii])_?[Tt][Oo][Kk][Ee][Nn]$|(?:^|_)(?:[Aa][Pp][Ii]|[Aa][Cc][Cc][Ee][Ss][Ss]|[Ss][Ee][Cc][Rr][Ee][Tt]|[Ss][Ii][Gg][Nn][Ii][Nn][Gg]|[Pp][Rr][Ii][Vv][Aa][Tt][Ee]|[Ee][Nn][Cc][Rr][Yy][Pp][Tt][Ii][Oo][Nn]|[Aa][Cc][Cc][Oo][Uu][Nn][Tt]|[Ss][Ee][Rr][Vv][Ii][Cc][Ee]_[Aa][Cc][Cc][Oo][Uu][Nn][Tt])_?[Kk][Ee][Yy]$|[Cc][Ee][Rr][Tt]_(?:[Pp][Ee][Mm]|[Kk][Ee][Yy])$|(?:^|_)[Aa][Ss][Ss][Ee][Rr][Tt][Ii][Oo][Nn]$|(?:^|_)[Ss][Ee][Cc][Rr][Ee][Tt](?:_|$)|(?:^|_)[Pp][Aa][Ss][Ss][Ww][Oo][Rr][Dd](?:_|$)|(?:^|_)(?:[Pp][Ww][Dd]|[Pp][Aa][Tt]|[Pp][Kk][Ee][Yy]|[Cc][Rr][Ee][Dd][Ss])(?:_|$)|(?:^|_)[Pp][Aa][Ss][Ss][Ww][Dd](?:_|$)|(?:^|_)[Cc][Ll][Ii][Ee][Nn][Tt]_[Ss][Ee][Cc][Rr][Ee][Tt](?:_|$)|(?:^|_)[Cc][Rr][Ee][Dd][Ee][Nn][Tt][Ii][Aa][Ll][Ss]?(?:_|$)|(?:^|_)[Cc][Oo][Nn][Nn][Ee][Cc][Tt][Ii][Oo][Nn]_[Ss][Tt][Rr][Ii][Nn][Gg](?:_|$)|^[Aa][Ss][Ss][Ee][Rr][Tt][Ii][Oo][Nn]$|^[Cc][Rr][Ee][Dd][Ee][Nn][Tt][Ii][Aa][Ll]$|^[Cc][Rr][Ee][Dd][Ee][Nn][Tt][Ii][Aa][Ll][Ss]$|^[Cc][Rr][Ee][Dd][Ss]$|^[Kk][Ee][Yy]$|^[Pp][Aa][Ss][Ss][Ww][Dd]$|^[Pp][Aa][Ss][Ss][Ww][Oo][Rr][Dd]$|^[Pp][Aa][Tt]$|^[Pp][Kk][Ee][Yy]$|^[Pp][Ww][Dd]$|^[Ss][Ee][Cc][Rr][Ee][Tt]$|^[Tt][Oo][Kk][Ee][Nn]$"
        }
      },
      "title": "Selections",
      "type": "object"
    },
    "tags": {
      "anyOf": [
        {
          "items": {
            "maxLength": 64,
            "minLength": 1,
            "pattern": "^\\S(?:[\\s\\S]*\\S)?$",
            "type": "string"
          },
          "maxItems": 50,
          "type": "array"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Grouping/search labels (max 50, each 1-64 chars, unique, trimmed).",
      "title": "Tags",
      "uniqueItems": true
    }
  },
  "required": [
    "connector_id"
  ],
  "title": "Analitiq Connection",
  "type": "object",
  "version": "10.0.0"
}
