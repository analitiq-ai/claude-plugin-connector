{
  "$defs": {
    "BatchingConfig": {
      "additionalProperties": false,
      "description": "Pipeline-wide record batching defaults.",
      "patternProperties": {
        "^x-[a-z0-9]+(-[a-z0-9]+)*$": {}
      },
      "properties": {
        "batch_size": {
          "default": 100,
          "description": "Records per batch",
          "maximum": 100000,
          "minimum": 1,
          "title": "Batch Size",
          "type": "integer"
        },
        "max_concurrent_batches": {
          "default": 3,
          "description": "Per-binding cap for each (stream, destination) execution binding (not a pipeline-wide aggregate ceiling)",
          "maximum": 100,
          "minimum": 1,
          "title": "Max Concurrent Batches",
          "type": "integer"
        }
      },
      "title": "BatchingConfig",
      "type": "object"
    },
    "EngineConfig": {
      "additionalProperties": false,
      "description": "Per-run resource request.\n\nMinimums (`vcpu>=0.5`, `memory>=1024`) reserve the 0.25 vCPU / 512 MB\nsidecar baseline so the engine container always has at least the runtime\nfloor (0.25 vCPU / 512 MB) after subtracting the destination container.",
      "patternProperties": {
        "^x-[a-z0-9]+(-[a-z0-9]+)*$": {}
      },
      "properties": {
        "memory": {
          "default": 8192,
          "description": "Memory allocation in MB",
          "minimum": 1024,
          "title": "Memory",
          "type": "integer"
        },
        "vcpu": {
          "default": 1.0,
          "description": "vCPU allocation",
          "minimum": 0.5,
          "title": "Vcpu",
          "type": "number"
        }
      },
      "title": "EngineConfig",
      "type": "object"
    },
    "ErrorHandlingConfig": {
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "max_retries": {
                "const": 0
              }
            },
            "required": [
              "max_retries"
            ]
          },
          "then": {
            "properties": {
              "retry_delay_seconds": {
                "oneOf": [
                  {
                    "const": 0
                  },
                  {
                    "type": "null"
                  }
                ]
              }
            }
          }
        }
      ],
      "description": "Runtime error handling. Strategy controls behavior after retries are exhausted.",
      "patternProperties": {
        "^x-[a-z0-9]+(-[a-z0-9]+)*$": {}
      },
      "properties": {
        "max_retries": {
          "default": 3,
          "description": "Retry attempts before strategy",
          "maximum": 5,
          "minimum": 0,
          "title": "Max Retries",
          "type": "integer"
        },
        "retry_delay_seconds": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Non-negative integer delay between retry attempts. Required when max_retries > 0; must be omitted or 0 when max_retries is 0.",
          "title": "Retry Delay Seconds"
        },
        "strategy": {
          "default": "dlq",
          "description": "Action after retries are exhausted",
          "enum": [
            "fail",
            "dlq",
            "skip"
          ],
          "title": "Strategy",
          "type": "string"
        }
      },
      "title": "ErrorHandlingConfig",
      "type": "object"
    },
    "LoggingConfig": {
      "additionalProperties": false,
      "description": "Runtime logging and metrics defaults.",
      "patternProperties": {
        "^x-[a-z0-9]+(-[a-z0-9]+)*$": {}
      },
      "properties": {
        "log_level": {
          "default": "INFO",
          "description": "Logging level",
          "enum": [
            "DEBUG",
            "INFO",
            "WARNING",
            "ERROR",
            "CRITICAL"
          ],
          "title": "Log Level",
          "type": "string"
        },
        "metrics_enabled": {
          "default": true,
          "description": "Whether runtime metrics emission is enabled",
          "title": "Metrics Enabled",
          "type": "boolean"
        }
      },
      "title": "LoggingConfig",
      "type": "object"
    },
    "PipelineConnections": {
      "additionalProperties": false,
      "description": "Connection set available to every stream in the pipeline.",
      "patternProperties": {
        "^x-[a-z0-9]+(-[a-z0-9]+)*$": {}
      },
      "properties": {
        "destinations": {
          "description": "Non-empty list of unique versioned destination connection IDs. A destination ID may equal `source`.",
          "examples": [
            [
              "00000000-0000-4000-8000-000000000002_v1"
            ]
          ],
          "items": {
            "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}_v[1-9][0-9]*$",
            "type": "string"
          },
          "minItems": 1,
          "title": "Destinations",
          "type": "array",
          "uniqueItems": true
        },
        "source": {
          "description": "Versioned source connection ID (e.g. 'uuid_v1')",
          "examples": [
            "00000000-0000-4000-8000-000000000001_v1"
          ],
          "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}_v[1-9][0-9]*$",
          "title": "Source",
          "type": "string"
        }
      },
      "required": [
        "source",
        "destinations"
      ],
      "title": "PipelineConnections",
      "type": "object"
    },
    "RuntimeConfig": {
      "additionalProperties": false,
      "description": "Pipeline-wide execution defaults.",
      "patternProperties": {
        "^x-[a-z0-9]+(-[a-z0-9]+)*$": {}
      },
      "properties": {
        "batching": {
          "$ref": "#/$defs/BatchingConfig"
        },
        "buffer_size": {
          "default": 5000,
          "description": "Record buffer size",
          "minimum": 100,
          "title": "Buffer Size",
          "type": "integer"
        },
        "error_handling": {
          "$ref": "#/$defs/ErrorHandlingConfig"
        },
        "logging": {
          "$ref": "#/$defs/LoggingConfig"
        }
      },
      "title": "RuntimeConfig",
      "type": "object"
    },
    "ScheduleConfig": {
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "type": {
                "const": "manual"
              }
            },
            "required": [
              "type"
            ]
          },
          "then": {
            "not": {
              "anyOf": [
                {
                  "required": [
                    "interval_minutes"
                  ]
                },
                {
                  "required": [
                    "cron_expression"
                  ]
                }
              ]
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "interval"
              }
            },
            "required": [
              "type"
            ]
          },
          "then": {
            "not": {
              "required": [
                "cron_expression"
              ]
            },
            "required": [
              "interval_minutes"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "cron"
              }
            },
            "required": [
              "type"
            ]
          },
          "then": {
            "not": {
              "required": [
                "interval_minutes"
              ]
            },
            "required": [
              "cron_expression"
            ]
          }
        }
      ],
      "description": "Pipeline schedule. See the published Analitiq schema documentation.",
      "patternProperties": {
        "^x-[a-z0-9]+(-[a-z0-9]+)*$": {}
      },
      "properties": {
        "cron_expression": {
          "anyOf": [
            {
              "pattern": "^cron\\(.+\\)$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "AWS/EventBridge wrapper string matching '^cron\\(.+\\)$' (cron schedule only; e.g. 'cron(0 6 * * ? *)')",
          "title": "Cron Expression"
        },
        "interval_minutes": {
          "anyOf": [
            {
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Positive integer minutes (interval schedule only)",
          "title": "Interval Minutes"
        },
        "timezone": {
          "default": "UTC",
          "description": "IANA timezone name",
          "title": "Timezone",
          "type": "string"
        },
        "type": {
          "default": "manual",
          "description": "Schedule type",
          "enum": [
            "manual",
            "interval",
            "cron"
          ],
          "title": "Type",
          "type": "string"
        }
      },
      "title": "ScheduleConfig",
      "type": "object"
    }
  },
  "$id": "https://schemas.analitiq.ai/pipeline/2.0.0.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Public JSON Schema contract for Analitiq pipeline documents \u2014 the persisted-record shape returned by the pipeline service. Authored fields plus required server-managed fields (pipeline_id, version, org_id, created_at, updated_at). Source of truth: k2m.models.pipeline.PipelineDocument (Pydantic).",
  "patternProperties": {
    "^x-[a-z0-9]+(-[a-z0-9]+)*$": {}
  },
  "properties": {
    "$schema": {
      "anyOf": [
        {
          "const": "https://schemas.analitiq.ai/pipeline/latest.json",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Pipeline schema URL (optional in API payloads).",
      "title": "$Schema"
    },
    "alias": {
      "description": "Stable pipeline slug; matches '^[a-z0-9][a-z0-9_-]*$'. Immutable after creation.",
      "pattern": "^[a-z0-9][a-z0-9_-]*$",
      "title": "Alias",
      "type": "string"
    },
    "connections": {
      "$ref": "#/$defs/PipelineConnections",
      "description": "Source and destination connection references"
    },
    "created_at": {
      "description": "Creation timestamp (server-managed).",
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "description": {
      "anyOf": [
        {
          "maxLength": 2000,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "User-facing summary",
      "title": "Description"
    },
    "display_name": {
      "anyOf": [
        {
          "maxLength": 120,
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "User-facing pipeline label (1-120 chars, no leading/trailing whitespace)",
      "title": "Display Name"
    },
    "engine": {
      "$ref": "#/$defs/EngineConfig"
    },
    "org_id": {
      "description": "Tenant identifier (server-managed).",
      "title": "Org Id",
      "type": "string"
    },
    "pipeline_id": {
      "description": "Stable base pipeline UUID (server-managed).",
      "title": "Pipeline Id",
      "type": "string"
    },
    "runtime": {
      "$ref": "#/$defs/RuntimeConfig"
    },
    "schedule": {
      "$ref": "#/$defs/ScheduleConfig"
    },
    "status": {
      "default": "draft",
      "description": "Pipeline lifecycle status",
      "enum": [
        "draft",
        "active",
        "inactive"
      ],
      "title": "Status",
      "type": "string"
    },
    "streams": {
      "description": "Ordered list of versioned stream IDs",
      "items": {
        "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}_v[1-9][0-9]*$",
        "type": "string"
      },
      "title": "Streams",
      "type": "array",
      "uniqueItems": true
    },
    "tags": {
      "anyOf": [
        {
          "items": {
            "maxLength": 64,
            "minLength": 1,
            "type": "string"
          },
          "maxItems": 50,
          "type": "array"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Grouping/search labels (max 50, each 1-64 chars, unique, trimmed)",
      "title": "Tags"
    },
    "updated_at": {
      "description": "Last update timestamp (server-managed).",
      "format": "date-time",
      "title": "Updated At",
      "type": "string"
    },
    "version": {
      "description": "Pipeline configuration version (server-managed).",
      "minimum": 1,
      "title": "Version",
      "type": "integer"
    }
  },
  "required": [
    "alias",
    "connections",
    "pipeline_id",
    "version",
    "org_id",
    "created_at",
    "updated_at"
  ],
  "title": "Analitiq Pipeline",
  "type": "object",
  "version": "2.0.0"
}
