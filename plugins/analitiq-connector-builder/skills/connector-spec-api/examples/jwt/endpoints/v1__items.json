{
  "$schema": "https://schemas.analitiq.ai/api-endpoint/latest.json",
  "endpoint_id": "v1__items",
  "operations": {
    "read": {
      "params": {
        "limit": { "in": "query", "type": "integer", "required": false, "controlled_by": "pagination" },
        "page": { "in": "query", "type": "integer", "required": false, "controlled_by": "pagination" }
      },
      "request": {
        "method": "GET",
        "path": "/v1/items",
        "query": {
          "limit": { "from_param": "limit" },
          "page": { "from_param": "page" }
        },
        "headers": { "Accept": "application/json" }
      },
      "pagination": {
        "type": "page",
        "page": { "param": "page", "initial": 1, "increment_by": 1 },
        "limit": { "param": "limit", "default": { "ref": "runtime.batch_size" }, "max": 100 },
        "stop_when": { "empty": { "ref": "response.body.data" } }
      },
      "response": {
        "records": { "ref": "response.body.data" },
        "schema": {
          "type": "object",
          "properties": {
            "data": {
              "type": "array",
              "native_type": "array",
              "arrow_type": "List",
              "items": {
                "type": "object",
                "native_type": "object",
                "arrow_type": "Object",
                "properties": {
                  "id": { "type": "string", "native_type": "string", "arrow_type": "Utf8" },
                  "name": { "type": "string", "native_type": "string", "arrow_type": "Utf8" },
                  "active": { "type": "boolean", "native_type": "boolean", "arrow_type": "Boolean" }
                }
              }
            }
          }
        }
      }
    }
  }
}
