{
  "$schema": "https://schemas.analitiq.ai/connector/latest.json",
  "kind": "api",
  "connector_id": "fixture-oauth-pkce-valid",
  "version": "1.0.0",
  "default_transport": "api",
  "transports": {
    "api": {
      "transport_type": "http",
      "base_url": "https://api.example.com",
      "headers": {
        "Authorization": {
          "template": "Bearer ${auth.access_token}"
        }
      }
    }
  },
  "auth": {
    "type": "oauth2_authorization_code",
    "authorize": {
      "method": "GET",
      "path": {
        "template": "/oauth/authorize?code_challenge=${runtime.oauth.code_challenge}&code_challenge_method=${runtime.oauth.code_challenge_method}&state=${runtime.oauth.state}&redirect_uri=${runtime.oauth.redirect_uri}"
      }
    },
    "token_exchange": {
      "method": "POST",
      "path": "/oauth/token",
      "body": {
        "template": "grant_type=authorization_code&code=${runtime.oauth.code}&code_verifier=${runtime.oauth.pkce_verifier}&redirect_uri=${runtime.oauth.redirect_uri}"
      }
    }
  },
  "connection_contract": {
    "inputs": {
      "client_id": {
        "source": "platform",
        "phase": "auth",
        "storage": "connection.parameters",
        "type": "string",
        "required": true
      },
      "client_secret": {
        "source": "platform",
        "phase": "auth",
        "storage": "secrets",
        "type": "string",
        "required": true,
        "secret": true
      }
    }
  }
}
