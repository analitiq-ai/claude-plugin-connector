{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "bump-minor-pre-major": true,
  "bump-patch-for-minor-pre-major": true,
  "separate-pull-requests": true,
  "include-component-in-tag": true,
  "plugins": [
    {
      "type": "linked-versions",
      "groupName": "analitiq-contracts",
      "components": [
        "contract-models",
        "validator"
      ]
    }
  ],
  "packages": {
    "plugins/analitiq-connector-builder": {
      "release-type": "simple",
      "component": "analitiq-connector-builder",
      "changelog-path": "CHANGELOG.md",
      "extra-files": [
        {
          "type": "json",
          "path": ".claude-plugin/plugin.json",
          "jsonpath": "$.version"
        }
      ]
    },
    "plugins/analitiq-pipeline-builder": {
      "release-type": "simple",
      "component": "analitiq-pipeline-builder",
      "changelog-path": "CHANGELOG.md",
      "extra-files": [
        {
          "type": "json",
          "path": ".claude-plugin/plugin.json",
          "jsonpath": "$.version"
        }
      ]
    },
    "packages/contract-models": {
      "release-type": "python",
      "component": "contract-models",
      "prerelease": true,
      "changelog-path": "CHANGELOG.md"
    },
    "packages/validator": {
      "release-type": "python",
      "component": "validator",
      "prerelease": true,
      "changelog-path": "CHANGELOG.md",
      "extra-files": [
        "pyproject.toml"
      ]
    }
  }
}
